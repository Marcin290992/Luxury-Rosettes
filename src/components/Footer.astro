---
import { Image } from 'astro:assets';
import logoImage from '../assets/img/bengal-logo-web.webp';
---

<footer class="footer-gold-top bg-cream px-6 pb-10 pt-12 sm:px-10 sm:pt-14 lg:px-16">
  <div class="mx-auto max-w-350">

    <!-- Top -->
    <div class="flex flex-col items-center gap-8 sm:flex-row sm:items-start sm:justify-between">

      <!-- Brand -->
      <div class="flex flex-col items-center gap-3 sm:items-start">
        <Image
          src={logoImage}
          alt="Luxury Rosettes"
          class="h-16 w-auto opacity-90 sm:h-18"
          loading="lazy"
          widths={[180, 320]}
          sizes="180px"
          quality={85}
        />
        <p class="font-body text-[0.6rem] font-semibold uppercase tracking-[3px] text-dark/45">
          Luxury Rosettes
        </p>
        <p class="font-body text-[0.55rem] font-medium uppercase tracking-[1.5px] text-dark/30">
          TICA Registered Bengal Cattery
        </p>
      </div>

      <!-- Social -->
      <div class="flex items-center gap-3">
        <a
          href="https://www.facebook.com/people/Luxuryrosettes-Bengal-cattery/100091469460702/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="flex h-9 w-9 items-center justify-center border border-dark/15 text-dark/40 transition-all duration-300 hover:border-gold-dark/40 hover:text-gold-dark"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/luxuryrosettes"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="flex h-9 w-9 items-center justify-center border border-dark/15 text-dark/40 transition-all duration-300 hover:border-gold-dark/40 hover:text-gold-dark"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
        </a>
        <a
          href="https://wa.me/447514951289"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="flex h-9 w-9 items-center justify-center border border-dark/15 text-dark/40 transition-all duration-300 hover:border-gold-dark/40 hover:text-gold-dark"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </a>
      </div>

    </div>

    <!-- Divider -->
    <div class="my-8 h-px w-full bg-dark/8 sm:my-10"></div>

    <!-- Bottom -->
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:justify-between">

      <nav class="flex flex-wrap items-center justify-center gap-x-7 gap-y-3 sm:justify-start" aria-label="Footer navigation">
        <a href="/#about" class="font-body text-[0.78rem] text-dark/55 transition-colors duration-300 hover:text-gold-dark">About</a>
        <a href="/available-kittens" class="font-body text-[0.78rem] text-dark/55 transition-colors duration-300 hover:text-gold-dark">Kittens</a>
        <a href="/gallery" class="font-body text-[0.78rem] text-dark/55 transition-colors duration-300 hover:text-gold-dark">Gallery</a>
        <button type="button" data-contact-trigger class="font-body text-[0.78rem] text-dark/55 transition-colors duration-300 hover:text-gold-dark">Contact</button>
        <a href="mailto:sylwiab21@yahoo.co.uk" class="font-body text-[0.78rem] text-dark/55 transition-colors duration-300 hover:text-gold-dark">sylwiab21@yahoo.co.uk</a>
      </nav>

      <div class="text-center sm:text-right">
        <p class="font-body text-[0.68rem] text-dark/30">© 2025 Luxury Rosettes. All rights reserved.</p>
        <p class="mt-1 font-body text-[0.68rem] text-dark/25">
          Design by <a href="https://primetriskelion.com" target="_blank" rel="noopener noreferrer" class="transition-colors duration-300 hover:text-gold-dark">Prime Triskelion</a>
        </p>
      </div>

    </div>

  </div>
</footer>

<style>
  .footer-gold-top {
    position: relative;
  }
  .footer-gold-top::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--gold) 50%, transparent 100%);
  }
</style>
