---
import { Image } from 'astro:assets';
import heroImage from '../assets/img/hero_img.webp';
---

<section class="hero-intro relative min-h-svh overflow-hidden bg-dark" data-nav-dark>
	<div class="absolute inset-0">
		<div class="hero-ken-burns h-full w-full" style="opacity:0;visibility:hidden">
			<Image
				src={heroImage}
				alt="Luxury Bengal cat"
				class="h-full w-full object-cover object-[55%_center] md:object-center lg:object-[62%_center]"
				widths={[640, 768, 1024, 1280, 1536, 1920, 2560]}
				sizes="100vw"
				loading="eager"
				fetchpriority="high"
				format="webp"
			/>
		</div>
		<div class="hero-overlay absolute inset-0 bg-[linear-gradient(180deg,rgba(10,10,10,0.60)_0%,rgba(10,10,10,0.08)_42%,rgba(10,10,10,0.78)_100%)]"></div>
		<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(8,12,20,0.85)_0%,rgba(8,12,20,0.52)_28%,rgba(8,12,20,0.18)_54%,rgba(8,12,20,0)_100%)]"></div>
	</div>

	<div class="relative z-10 flex min-h-svh w-full items-end justify-center px-5 pb-5 md:pb-10 lg:justify-start lg:px-14 lg:pb-12 xl:px-16">
		<div class="max-w-72 text-center md:max-w-sm lg:max-w-184 lg:text-left xl:max-w-208">

			<div class="hero-content" style="opacity:0;visibility:hidden">
				<h1
					class="hero-title font-heading text-[2.2rem] leading-[1.08] tracking-[-0.01em] font-light text-cream sm:text-[2.8rem] md:text-[2.4rem] md:leading-[1.1] md:tracking-[0.01em] lg:text-[2.8rem] xl:text-[3.1rem] 2xl:text-[3.6rem]"
					style="opacity:0;visibility:hidden"
				>
					<span class="block">The Elegance of the</span>
					<span class="mt-1 block italic">Wild at Home</span>
				</h1>

				<span
					class="hero-line mx-auto mt-3 block h-px w-16 bg-(--gold-line) md:mt-5 md:w-24 lg:mx-0 lg:mt-6 lg:w-40"
					style="opacity:0;visibility:hidden"
				></span>

				<p
					class="hero-sub mt-2 font-body text-[0.78rem] font-light leading-[1.65] tracking-[0.02em] text-cream/80 md:mt-4 md:text-[0.82rem] lg:mt-6 lg:max-w-sm lg:text-[0.88rem] lg:leading-[1.85]"
					style="opacity:0;visibility:hidden"
				>
					<span class="md:hidden">Champion bloodlines. Raised with purpose.</span>
					<span class="hidden md:inline">Handpicked kittens, raised with care and championship standards.</span>
				</p>
			</div>

			<a
				href="/available-kittens"
				style="opacity:0;visibility:hidden"
				class="hero-cta group relative mt-4 inline-flex items-center justify-center overflow-hidden px-9 py-3 font-body text-[0.65rem] font-semibold uppercase tracking-[0.3em] text-cream transition-colors duration-300 hover:text-gold focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-gold/50 md:mt-6 md:px-9 md:py-3 md:text-[0.6rem] lg:mt-11 lg:px-11 lg:py-4 lg:text-[0.62rem]"
			>
				<span class="cta-border-bg absolute inset-0 z-0" aria-hidden="true"></span>
				<span class="cta-glow absolute inset-0 z-1" aria-hidden="true"></span>
				<span class="absolute inset-px z-2 bg-dark" aria-hidden="true"></span>
				<span class="cta-shine absolute inset-0 z-3" aria-hidden="true"></span>
				<span class="relative z-4">Explore Kittens</span>
			</a>
		</div>
	</div>
</section>

<style>
	.cta-border-bg {
		background: rgba(250, 248, 243, 0.28);
	}

	.cta-glow {
		background: radial-gradient(
			circle 90px at var(--mx, -200%) var(--my, -200%),
			rgba(212, 175, 55, 0.9) 0%,
			transparent 70%
		);
		opacity: 0;
		transition: opacity 0.35s ease;
		pointer-events: none;
	}

	.hero-cta:hover .cta-glow {
		opacity: 1;
	}

	.cta-shine {
		width: 55%;
		height: 100%;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(255, 255, 255, 0.18) 50%,
			transparent 100%
		);
		transform: translateX(-200%) skewX(-15deg);
		animation: cta-shine 5s ease-in-out infinite;
		pointer-events: none;
	}

	@keyframes cta-shine {
		0%   { transform: translateX(-200%) skewX(-15deg); }
		18%  { transform: translateX(320%)  skewX(-15deg); }
		100% { transform: translateX(320%)  skewX(-15deg); }
	}
</style>

<noscript>
	<style>
		.hero-ken-burns,
		.hero-content,
		.hero-title,
		.hero-line,
		.hero-cta,
		.hero-sub {
			opacity: 1 !important;
			visibility: visible !important;
			transform: none !important;
		}
	</style>
</noscript>

<script>
	import gsap from 'gsap';

	type Killable = { kill(): void };
	let heroCleanup: (() => void) | null = null;
	let ctaController: AbortController | null = null;

	function initHeroAnimation(): void {
		if (heroCleanup) {
			heroCleanup();
			heroCleanup = null;
		}

		const heroImg     = document.querySelector<HTMLElement>('.hero-ken-burns');
		const heroTitle   = document.querySelector<HTMLElement>('.hero-title');
		const heroLine    = document.querySelector<HTMLElement>('.hero-line');
		const heroCta     = document.querySelector<HTMLElement>('.hero-cta');
		const heroContent = document.querySelector<HTMLElement>('.hero-content');
		const heroOverlay = document.querySelector<HTMLElement>('.hero-overlay');
		const heroSub     = document.querySelector<HTMLElement>('.hero-sub');
		const floatingNav = document.getElementById('floatingNav');

		if (!heroImg || !heroTitle || !heroOverlay || !heroCta || !heroLine || !heroContent) return;

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const isLg                 = window.matchMedia('(min-width: 1024px)').matches;
		const INTRO_KEY            = 'luxuryrosettes:hero-intro-played:session';

		let hasSeenIntro = false;
		try { hasSeenIntro = sessionStorage.getItem(INTRO_KEY) === '1'; } catch { /* storage blocked */ }

		const motion = isLg
			? { from: { scale: 1.03, xPercent: 0, yPercent: 0 }, to: { scale: 1.18, xPercent: -1.2, yPercent: -0.85 } }
			: { from: { scale: 1.02, xPercent: 0, yPercent: 0 }, to: { scale: 1.2,  xPercent: -1.5, yPercent: -1.05 } };

		const tweens: Killable[] = [];

		if (!prefersReducedMotion && !hasSeenIntro) {
			gsap.set(heroImg,     { autoAlpha: 0, scale: motion.from.scale + 0.05, xPercent: 0, yPercent: 0, transformOrigin: '50% 50%' });
			gsap.set(heroOverlay, { opacity: 0 });
			gsap.set(heroContent, { autoAlpha: 0 });
			gsap.set(heroTitle,   { autoAlpha: 0, y: 22 });
			gsap.set(heroLine,    { autoAlpha: 0, scaleX: 0, transformOrigin: isLg ? 'left center' : 'center center' });
			gsap.set(heroCta,     { autoAlpha: 0, y: 16 });
			if (heroSub) gsap.set(heroSub, { autoAlpha: 0, y: 14 });

			const tl = gsap.timeline({ defaults: { overwrite: 'auto' } });
			tweens.push(tl);

			tl.to(heroImg,     { autoAlpha: 1, scale: motion.from.scale, duration: 1.4, ease: 'power2.inOut' }, 0)
			  .to(heroOverlay, { opacity: 1, duration: 1.2, ease: 'power2.out' }, 0.2);

			// Nav slides in via CSS transform transition — no GSAP opacity on nav to avoid
			// compositing isolation that breaks backdrop-filter on mobile browsers
			if (floatingNav) tl.call(() => floatingNav.classList.remove('nav-hidden'), [], 0.7);

			tl.to(heroContent, { autoAlpha: 1, duration: 0.01 }, 0.85)
			  .to(heroTitle,   { autoAlpha: 1, y: 0, duration: 0.6, ease: 'power2.out' }, 0.85)
			  .to(heroLine,    { autoAlpha: 1, scaleX: 1, duration: 0.45, ease: 'power2.out' }, 1.2);

			if (heroSub) tl.to(heroSub, { autoAlpha: 1, y: 0, duration: 0.45, ease: 'power2.out' }, 1.1);

			tl.to(heroCta, { autoAlpha: 1, y: 0, duration: 0.4, ease: 'power2.out' }, 1.4);

			tl.eventCallback('onComplete', () => {
				try { sessionStorage.setItem(INTRO_KEY, '1'); } catch { /* */ }
				tweens.push(gsap.to(heroImg, { ...motion.to, duration: 32, ease: 'sine.inOut', repeat: -1, yoyo: true }));
			});
		} else {
			gsap.set(heroImg,     { autoAlpha: 1, ...motion.from, transformOrigin: '50% 50%' });
			gsap.set(heroTitle,   { autoAlpha: 1, y: 0 });
			gsap.set(heroLine,    { autoAlpha: 1, scaleX: 1 });
			gsap.set(heroCta,     { autoAlpha: 1, y: 0 });
			gsap.set(heroContent, { autoAlpha: 1 });
			gsap.set(heroOverlay, { opacity: 1 });
			if (heroSub) gsap.set(heroSub, { autoAlpha: 1, y: 0 });

			if (floatingNav) {
				// Instant show, no slide animation
				floatingNav.style.transition = 'none';
				floatingNav.classList.remove('nav-hidden');
				floatingNav.offsetHeight; // force reflow before restoring transition
				floatingNav.style.transition = '';
			}

			if (!prefersReducedMotion) {
				tweens.push(gsap.to(heroImg, { ...motion.to, duration: 32, ease: 'sine.inOut', repeat: -1, yoyo: true }));
			}
		}

		heroCleanup = () => {
			tweens.forEach((t) => t.kill());
			tweens.length = 0;
		};

		ctaController?.abort();
		ctaController = new AbortController();
		const { signal } = ctaController;
		const ctaEl = heroCta as HTMLAnchorElement;

		ctaEl.addEventListener('mousemove', (e: MouseEvent) => {
			const rect = ctaEl.getBoundingClientRect();
			ctaEl.style.setProperty('--mx', `${e.clientX - rect.left}px`);
			ctaEl.style.setProperty('--my', `${e.clientY - rect.top}px`);
		}, { signal });

		ctaEl.addEventListener('mouseleave', () => {
			ctaEl.style.setProperty('--mx', '-200%');
			ctaEl.style.setProperty('--my', '-200%');
		}, { signal });
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initHeroAnimation, { once: true });
	} else {
		initHeroAnimation();
	}

	document.addEventListener('astro:after-swap', initHeroAnimation);

	document.addEventListener('astro:before-swap', () => {
		if (heroCleanup) {
			heroCleanup();
			heroCleanup = null;
		}
		ctaController?.abort();
		ctaController = null;
	});
</script>
