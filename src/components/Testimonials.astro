---

<section class="bg-cream py-10 sm:py-18 lg:py-24">
  <div class="mx-auto w-full max-w-330 px-4 sm:px-8 lg:px-16">
    <header class="text-center">
      <p class="font-body text-[0.65rem] font-semibold uppercase tracking-[2.8px] text-dark/45 sm:text-[0.72rem] lg:text-[0.76rem]">
        Client Love
      </p>
      <h2 class="mt-3 font-heading text-[1.5rem] font-light leading-[1.1] tracking-tight text-gold-dark sm:text-[2rem] lg:text-[2.2rem] xl:text-[2.4rem]">
        Loved by Our Bengal Families
      </h2>
      <span class="mx-auto mt-4 block h-px w-16 bg-(--gold-line) sm:w-20"></span>
    </header>

    <div class="testi-wrap relative mt-10 sm:mt-14">
      <div class="testi-track" id="testiTrack">
        {testimonials.map((t) => (
          <div class="testi-card">
            <div class="testi-stars" aria-hidden="true">★★★★★</div>
            <p class="testi-quote">&ldquo;{t.quote}&rdquo;</p>
            <div class="testi-name">{t.name}</div>
            <div class="testi-context">{t.context}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="testi-controls">
      <button type="button" class="testi-btn" id="testiPrev" aria-label="Previous testimonial">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M11 14L6 9l5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button type="button" class="testi-btn" id="testiNext" aria-label="Next testimonial">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><path d="M7 4l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .testi-wrap {
    overflow: hidden;
  }

  .testi-track {
    display: flex;
    gap: 1.75rem;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    padding: 0.25rem 0.25rem 1rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .testi-track::-webkit-scrollbar {
    display: none;
  }

  .testi-card {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid rgba(212, 175, 55, 0.18);
    border-radius: 10px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    padding: 2rem 1.75rem;
    text-align: left;
    box-sizing: border-box;
  }

  .testi-stars {
    color: var(--color-gold);
    font-size: 0.85rem;
    letter-spacing: 2px;
    margin-bottom: 1.1rem;
  }

  /* Fixed to 7 lines (min-height reserves the space, line-clamp caps the
     overflow) so every card is the same height regardless of how long the
     original review is — long reviews truncate with an ellipsis. */
  .testi-quote {
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 400;
    font-size: 1.08rem;
    line-height: 1.6;
    color: var(--color-text-primary);
    margin: 0 0 1.5rem;
    min-height: 11.2em;
    display: -webkit-box;
    -webkit-line-clamp: 7;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .testi-name {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-gold-dark);
    margin-top: auto;
  }

  .testi-context {
    font-family: var(--font-body);
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    margin-top: 0.2rem;
  }

  @media (min-width: 640px) {
    .testi-card { flex: 0 0 calc(50% - 0.875rem); }
  }

  @media (min-width: 1024px) {
    .testi-card { flex: 0 0 calc(33.333% - (1.75rem * 2 / 3)); }
  }

  .testi-controls {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .testi-btn {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid rgba(212, 175, 55, 0.38);
    background: rgba(255, 255, 255, 0.9);
    color: #9f7f2f;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .testi-btn:hover {
      background: rgba(212, 175, 55, 0.08);
      border-color: rgba(212, 175, 55, 0.55);
    }
  }
</style>

<script>
  function initTestimonials() {
    const track = document.getElementById('testiTrack');
    const prevBtn = document.getElementById('testiPrev');
    const nextBtn = document.getElementById('testiNext');
    if (!track || !prevBtn || !nextBtn) return;

    const getScrollAmount = () => {
      const card = track.querySelector('.testi-card') as HTMLElement | null;
      const gap = parseInt(window.getComputedStyle(track).getPropertyValue('gap')) || 0;
      return card ? card.offsetWidth + gap : track.clientWidth;
    };

    prevBtn.addEventListener('click', () => {
      track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
    });
  }

  document.addEventListener('astro:page-load', initTestimonials);
</script>
