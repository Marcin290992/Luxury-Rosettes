---
import { Image } from 'astro:assets';
import awardsImage from '../../assets/img/awards.webp';
import { getParentCats, responsiveImage } from '../../lib/sanity';

const parentCats = await getParentCats();
const kita = parentCats.find((c) => c.role === 'Queen');
const draco = parentCats.find((c) => c.role === 'King');
const kitaPhoto = kita ? responsiveImage(kita.image, [640, 960, 1280]) : null;
const dracoPhoto = draco ? responsiveImage(draco.image, [640, 960, 1280]) : null;
---

<div class="bg-cream">

  <!-- ── KITA ─────────────────────────────────────────────── -->
  <section class="oc-section mx-auto max-w-screen-2xl overflow-hidden px-6 py-10 sm:px-10 sm:py-16 lg:px-14 lg:py-20 2xl:px-16 2xl:py-24">
    <div class="flex flex-col-reverse items-center gap-8 lg:flex-row lg:gap-8 xl:gap-12">

      <div class="w-full lg:w-1/2">
        <div class="oc-image overflow-hidden rounded-md">
          {kitaPhoto && (
            <img
              src={kitaPhoto.src}
              srcset={kitaPhoto.srcset}
              alt="Kita — Bengal Queen"
              class="w-full object-cover"
              sizes="(max-width: 1024px) 100vw, 50vw"
              loading="eager"
              fetchpriority="high"
            />
          )}
        </div>
      </div>

      <div class="w-full lg:w-1/2">
        <p class="oc-kicker font-body text-[0.65rem] font-semibold uppercase tracking-[2.8px] text-dark/45 sm:text-[0.72rem] lg:text-[0.76rem]">The Queen</p>
        <h2 class="oc-heading mt-3 font-heading text-[2rem] font-light leading-[1.1] tracking-tight text-gold-dark sm:text-[2.6rem] lg:text-[2.8rem] 2xl:text-[3.4rem]"><span class="italic">{kita?.name ?? 'Kita'}</span></h2>
        <span class="oc-line mb-8 mt-4 block h-px w-20 bg-(--gold-line)"></span>
        <div class="oc-text space-y-5 font-body text-[0.9rem] leading-[1.82] tracking-[0.003em] text-dark/80 sm:text-[0.95rem] 2xl:text-[1.05rem] 2xl:leading-[1.85]">
          {kita?.bio.map((paragraph) => <p>{paragraph}</p>)}
          {kita?.closingQuote && <p class="font-medium italic text-dark/75">{kita.closingQuote}</p>}
        </div>
      </div>

    </div>
  </section>

  <!-- Gold separator -->
  <div class="mx-auto h-px w-24 bg-(--gold-line) opacity-35"></div>

  <!-- ── DRACO ────────────────────────────────────────────── -->
  <section class="oc-section mx-auto max-w-screen-2xl overflow-hidden px-6 py-10 sm:px-10 sm:py-16 lg:px-14 lg:py-20 2xl:px-16 2xl:py-24">
    <div class="flex flex-col-reverse items-center gap-8 lg:flex-row-reverse lg:gap-8 xl:gap-12">

      <div class="w-full lg:w-1/2">
        <div class="oc-image overflow-hidden rounded-md">
          {dracoPhoto && (
            <img
              src={dracoPhoto.src}
              srcset={dracoPhoto.srcset}
              alt="Draco — Bengal King"
              class="w-full object-cover"
              sizes="(max-width: 1024px) 100vw, 50vw"
              loading="eager"
              fetchpriority="high"
            />
          )}
        </div>
      </div>

      <div class="w-full lg:w-1/2">
        <p class="oc-kicker font-body text-[0.65rem] font-semibold uppercase tracking-[2.8px] text-dark/45 sm:text-[0.72rem] lg:text-[0.76rem]">The King</p>
        <h2 class="oc-heading mt-3 font-heading text-[2rem] font-light leading-[1.1] tracking-tight text-gold-dark sm:text-[2.6rem] lg:text-[2.8rem] 2xl:text-[3.4rem]"><span class="italic">{draco?.name ?? 'Draco'}</span></h2>
        <span class="oc-line mb-8 mt-4 block h-px w-20 bg-(--gold-line)"></span>
        <div class="oc-text space-y-5 font-body text-[0.9rem] leading-[1.82] tracking-[0.003em] text-dark/80 sm:text-[0.95rem] 2xl:text-[1.05rem] 2xl:leading-[1.85]">
          {draco?.bio.map((paragraph) => <p>{paragraph}</p>)}
          {draco?.closingQuote && <p class="font-medium italic text-dark/75">{draco.closingQuote}</p>}
        </div>
      </div>

    </div>
  </section>

  <!-- Gold separator -->
  <div class="mx-auto h-px w-24 bg-(--gold-line) opacity-35"></div>

  <!-- ── WHERE BEAUTY MEETS HEART ──────────────────────────── -->
  <section class="oc-section oc-section--philosophy mx-auto max-w-screen-2xl overflow-hidden px-6 py-10 sm:px-10 sm:py-16 lg:px-14 lg:py-20 2xl:px-16 2xl:py-24">

    <div class="oc-philosophy-header mb-14 text-center sm:mb-16 lg:mb-20">
      <p class="oc-kicker font-body text-[0.65rem] font-semibold uppercase tracking-[2.8px] text-dark/45 sm:text-[0.72rem] lg:text-[0.76rem]">Our Philosophy</p>
      <h2 class="oc-heading mt-3 font-heading text-[2rem] font-light leading-[1.1] tracking-tight text-gold-dark sm:text-[2.6rem] lg:text-[2.8rem] 2xl:text-[3.4rem]">Where Beauty Meets <span class="italic">Heart</span></h2>
      <span class="oc-line mx-auto mt-4 block h-px w-20 bg-(--gold-line)"></span>
    </div>

    <div class="flex flex-col items-center gap-8 lg:flex-col-reverse lg:gap-10 xl:gap-12">

      <div class="w-full lg:w-1/2 lg:max-w-2xl lg:mx-auto">
        <div class="oc-text space-y-5 font-body text-[0.9rem] leading-[1.82] tracking-[0.003em] text-dark/80 sm:text-[0.95rem] 2xl:text-[1.05rem] 2xl:leading-[1.85]">
          <p>At Luxury Rosettes Bengals, our journey begins and ends with love, dedication and passion for the breed.</p>
          <p>Our Bengals are more than pedigree and titles. They are family members, companions and intelligent souls who bring joy, laughter and warmth into our everyday life.</p>
          <p>We are proud to share our carefully selected breeding cats, raised in a loving home and social environment, surrounded by care and attention from day one. Their health, temperament and exceptional type reflect the standards we believe in and work tirelessly to preserve.</p>
          <p>Every kitten born here carries not only world-class bloodlines, but also the values at the heart of our cattery: trust, integrity, and a deep respect for this extraordinary breed.</p>
          <p class="font-medium italic text-dark/75">Thank you for visiting our world. We look forward to helping you meet your future best friend, a kitten raised with passion, responsibility, and love.</p>
        </div>
      </div>

      <div class="w-full lg:w-1/2 lg:max-w-2xl lg:mx-auto">
        <div class="oc-image overflow-hidden rounded-md">
          <Image
            src={awardsImage}
            alt="Luxury Rosettes — Awards & Achievements"
            class="w-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 672px"
            format="webp"
            loading="eager"
          />
        </div>
      </div>

    </div>
  </section>

</div>

<!-- ── CTA ───────────────────────────────────────────────── -->
<section class="oc-cta bg-cream px-6 py-12 text-center sm:px-10 sm:py-16 lg:py-20 2xl:py-24">
  <h2 class="oc-cta-heading font-heading text-[1.5rem] font-light text-gold-dark sm:text-[1.8rem] lg:text-[2rem]">
    Your perfect Bengal companion <span class="italic">awaits.</span>
  </h2>
  <p class="oc-cta-text mt-3 font-body text-[0.9rem] font-normal leading-[1.8] text-dark/60 sm:text-[0.95rem]">
    We're happy to talk through anything before you decide.
  </p>
  <button
    type="button"
    data-contact-trigger
    class="oc-cta-btn mt-8 inline-flex items-center justify-center rounded-none border border-dark/20 px-11 py-[0.95rem] font-body text-[0.72rem] font-semibold uppercase tracking-[3px] text-dark/70 transition-all duration-500 hover:border-gold/60 hover:text-gold cursor-pointer"
  >
    Contact Us Today
  </button>
</section>

<style>
  .oc-text {
    max-width: 62ch;
  }
</style>
