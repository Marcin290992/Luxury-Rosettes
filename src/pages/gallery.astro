---
import Layout from '../layouts/Layout.astro';
import LuxuryNavShell from '../components/navigation/LuxuryNavShell.astro';
import Footer from '../components/Footer.astro';
import { Image, getImage } from 'astro:assets';
import galleryHeroImg from '../assets/img/gallery.webp';
import img1 from '../assets/img/gallery/1.webp';
import img2 from '../assets/img/gallery/2.webp';
import img3 from '../assets/img/gallery/3.webp';
import img4 from '../assets/img/gallery/4.webp';
import img5 from '../assets/img/gallery/5.webp';
import img6 from '../assets/img/gallery/6.webp';
import img7 from '../assets/img/gallery/7.webp';
import img8 from '../assets/img/gallery/8.webp';
import img9 from '../assets/img/gallery/9.webp';
import img10 from '../assets/img/gallery/10.webp';
import img12 from '../assets/img/gallery/12.webp';
import img13 from '../assets/img/gallery/13.webp';
import img14 from '../assets/img/gallery/14.webp';
import img15 from '../assets/img/gallery/15.webp';

const sources = [img1, img2, img3, img4, img5, img6, img7, img8, img9, img10, img12, img13, img14, img15];

const photos = await Promise.all(
  sources.map(async (src, i) => ({
    src,
    full: (await getImage({ src, width: 1600, format: 'webp' })).src,
    alt: `Luxury Rosettes Bengal cats — gallery photo ${i + 1}`,
  }))
);
---

<Layout title="Gallery | Luxury Rosettes">
  <LuxuryNavShell />

  <section class="gh subpage-hero-screen" data-nav-dark>
    <div class="gh__left">
      <div class="gh__text">
        <p class="gh__kicker">Our Collection</p>
        <h1 class="gh__heading">Gallery</h1>
        <p class="gh__desc">Beauty, wildness, and love at home.</p>
      </div>
    </div>
    <div class="gh__right" aria-hidden="true">
      <Image
        src={galleryHeroImg}
        alt=""
        class="gh__img"
        loading="eager"
        fetchpriority="high"
        widths={[640, 1024, 1440, 1920]}
        sizes="60vw"
        format="webp"
      />
    </div>
  </section>

  <section class="gallery-intro">
    <div class="gallery-intro__inner">
      <p class="gallery-intro__kicker">Life at Luxury Rosettes</p>
      <h2 class="gallery-intro__heading">Every Rosette Tells a Story</h2>
      <p class="gallery-intro__sub">A closer look at our cats, our kittens, and the everyday moments in between.</p>
    </div>
  </section>

  <section class="gallery-section">
    <div class="gallery-grid">
      {photos.map((photo, i) => (
        <button
          type="button"
          class="gallery-item"
          data-full={photo.full}
          data-alt={photo.alt}
          aria-label={`Open photo ${i + 1} of ${photos.length}`}
        >
          <Image
            src={photo.src}
            alt={photo.alt}
            widths={[320, 480, 640]}
            sizes="(max-width: 767px) 50vw, (max-width: 1279px) 33vw, 25vw"
            format="webp"
            loading={i < 4 ? 'eager' : 'lazy'}
          />
        </button>
      ))}
    </div>
  </section>

  <dialog id="lightbox" class="lightbox" aria-label="Photo viewer">
    <button type="button" class="lightbox__nav lightbox__nav--prev" data-lb-prev aria-label="Previous photo">&#10094;</button>
    <img id="lightboxImg" class="lightbox__img" alt="" />
    <button type="button" class="lightbox__nav lightbox__nav--next" data-lb-next aria-label="Next photo">&#10095;</button>
  </dialog>

  <Footer />
</Layout>

<script>
  function initGallery() {
    const dialog = document.getElementById('lightbox') as HTMLDialogElement | null;
    const image  = document.getElementById('lightboxImg') as HTMLImageElement | null;
    const items  = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-item'));
    if (!dialog || !image || !items.length) return;

    const sources = items.map((item) => item.dataset.full ?? '');
    const alts    = items.map((item) => item.dataset.alt ?? '');

    // Warm the cache up front so opening any photo never blocks on a fetch.
    sources.forEach((src) => { if (src) new Image().src = src; });

    let index = 0;

    // Decode off-screen before swapping the visible <img>, otherwise it keeps
    // rendering the previous photo until the new one finishes decoding.
    const show = async (i: number) => {
      index = i;
      const next = new Image();
      next.src = sources[index];
      try { await next.decode(); } catch {}
      image.src = sources[index];
      image.alt = alts[index];
    };

    const step = (delta: number) => show((index + delta + items.length) % items.length);

    items.forEach((item, i) => {
      item.addEventListener('click', async () => {
        await show(i);
        dialog.showModal();
      });
    });

    dialog.querySelector('[data-lb-prev]')?.addEventListener('click', () => step(-1));
    dialog.querySelector('[data-lb-next]')?.addEventListener('click', () => step(1));

    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });

    dialog.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') step(-1);
      if (e.key === 'ArrowRight') step(1);
    });
  }

  document.addEventListener('astro:page-load', initGallery);
</script>

<style>
  /* ── Intro ─────────────────────────────────────────────────── */
  .gallery-intro {
    background: #faf8f3;
    padding: 5rem 1.5rem 0;
  }

  .gallery-intro__inner {
    max-width: 620px;
    margin: 0 auto;
    text-align: center;
  }

  .gallery-intro__kicker {
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.45);
    margin: 0 0 0.875rem;
  }

  .gallery-intro__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.4rem);
    font-weight: 300;
    letter-spacing: -0.015em;
    color: var(--color-gold-dark);
    margin: 0;
  }

  .gallery-intro__sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.82;
    color: var(--color-text-secondary);
    margin: 0;
  }

  @media (max-width: 640px) {
    .gallery-intro { padding: 4rem 1.25rem 0; }
  }

  /* ── Grid ──────────────────────────────────────────────────── */
  .gallery-section {
    background: #faf8f3;
    padding: 4rem 1rem 5rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .gallery-item {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border: 0;
    padding: 0;
    background: none;
    cursor: zoom-in;
  }

  .gallery-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .gallery-item:hover :global(img) {
      transform: scale(1.05);
    }
  }

  @media (min-width: 768px) {
    .gallery-section { padding: 5rem 2rem 6rem; }
    .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  }

  @media (min-width: 1280px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  }

  /* ── Lightbox shell ────────────────────────────────────────── */
  .lightbox {
    /* Tailwind Preflight resets `margin: 0` globally, which otherwise
       overrides the dialog's native `margin: auto` centering. */
    margin: auto;
    border: 0;
    padding: 0;
    max-width: 92vw;
    max-height: 92vh;
    background: transparent;
    opacity: 0;
    scale: 0.96;
    transition:
      opacity var(--motion-base) var(--ease-premium),
      scale var(--motion-base) var(--ease-premium),
      overlay var(--motion-base) allow-discrete,
      display var(--motion-base) allow-discrete;
  }

  .lightbox[open] {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    scale: 1;
  }

  @starting-style {
    .lightbox[open] {
      opacity: 0;
      scale: 0.96;
    }
  }

  .lightbox::backdrop {
    background: rgba(8, 7, 6, 0);
    transition:
      background var(--motion-base) var(--ease-premium),
      overlay var(--motion-base) allow-discrete,
      display var(--motion-base) allow-discrete;
  }

  .lightbox[open]::backdrop {
    background: rgba(8, 7, 6, 0.92);
  }

  @starting-style {
    .lightbox[open]::backdrop {
      background: rgba(8, 7, 6, 0);
    }
  }

  .lightbox__img {
    max-width: 92vw;
    max-height: 92vh;
    object-fit: contain;
    display: block;
  }

  /* ── Lightbox controls ─────────────────────────────────────── */
  .lightbox__nav {
    position: fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: #faf8f3;
    cursor: pointer;
    top: 50%;
    transform: translateY(-50%);
    width: 2.75rem;
    height: 2.75rem;
    font-size: 1rem;
  }

  .lightbox__nav--prev { left: 1rem; }
  .lightbox__nav--next { right: 1rem; }

  @media (max-width: 640px) {
    .lightbox__nav { width: 2.25rem; height: 2.25rem; }
  }
</style>
